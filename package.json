{
  "name": "speakin",
  "private": true,
  "version": "1.1.0",
  "description": "SpeakIn声入 - 全局热键语音输入工具，支持豆包/百炼/千问 ASR 与 AI 优化",
  "license": "GPL-3.0",
  "author": "magiccodelab",
  "homepage": "https://github.com/magiccodelab/speakIn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magiccodelab/speakIn.git"
  },
  "bugs": {
    "url": "https://github.com/magiccodelab/speakIn/issues"
  },
  "keywords": [
    "voice-input",
    "asr",
    "tauri",
    "productivity",
    "speech-to-text",
    "doubao",
    "dashscope",
    "qwen"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "tauri:build:cached": "cross-env RUSTC_WRAPPER=sccache tauri build",
    "tauri:build:portable": "tauri build --no-bundle && node scripts/make-portable-zip.mjs",
    "tauri:build:portable:cached": "cross-env RUSTC_WRAPPER=sccache tauri build --no-bundle && node scripts/make-portable-zip.mjs"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.474.0",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
